<Window x:Class="UJS_ModbusMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UJS_ModbusMaster.Helpers"
        mc:Ignorable="d"
        Title="Modbus RTU Master - 物联网控制技术实验" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:BooleanToConnectTextConverter x:Key="BooleanToConnectTextConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="15">
            <TextBlock Text="Modbus RTU Master" 
                       Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- 串口设置区域 -->
        <GroupBox Grid.Row="1" Header="串口设置" Margin="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第一行 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="串口号:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailablePorts}" 
                          SelectedItem="{Binding SelectedPort}" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="波特率:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding BaudRates}" 
                          SelectedItem="{Binding BaudRate}" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="校验位:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="5" ItemsSource="{Binding Parities}" 
                          SelectedItem="{Binding Parity}" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="6" Text="数据位:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="7" ItemsSource="{Binding DataBitsList}" 
                          SelectedItem="{Binding DataBits}" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="8" Text="停止位:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="9" ItemsSource="{Binding StopBitsList}" 
                          SelectedItem="{Binding StopBits}" Margin="5"/>

                <!-- 第二行 -->
                <Button Grid.Row="1" Grid.Column="1" Content="刷新串口" Command="{Binding RefreshPortsCommand}" 
                        Margin="5" Padding="10,5"/>
                <Button Grid.Row="1" Grid.Column="3" Content="{Binding IsConnected, Converter={StaticResource BooleanToConnectTextConverter}}" 
                        Command="{Binding ConnectCommand}" Margin="5" Padding="10,5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#FFE74C3C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Background" Value="#FF27AE60"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Grid.Row="1" Grid.Column="6" Text="从站地址:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="7" Text="{Binding SlaveId}" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- 主内容区域 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 读取寄存器区域 -->
            <GroupBox Grid.Column="0" Header="读取保持寄存器 (功能码 03)" Margin="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 读取设置 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="起始地址:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ReadStartAddress}" Margin="5"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="寄存器数量:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ReadQuantity}" Margin="5"/>

                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Content="读取寄存器" 
                                Command="{Binding ReadRegistersCommand}" Margin="5" Padding="15,8"
                                Background="#FF3498DB" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <!-- 读取结果 -->
                    <TextBlock Grid.Row="1" Text="读取结果:" FontWeight="Bold" Margin="5,15,5,5"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="16进制:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HexResult}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="UInt16:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Uint16Result}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Float:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FloatResult}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="原始字节:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RawBytesResult}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5" FontFamily="Consolas"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- 写入寄存器区域 -->
            <GroupBox Grid.Column="1" Header="写入单个寄存器 (功能码 06)" Margin="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 写入设置 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="寄存器地址:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WriteAddress}" Margin="5"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="写入值:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding WriteValue}" Margin="5"/>

                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Content="写入寄存器" 
                                Command="{Binding WriteRegisterCommand}" Margin="5" Padding="15,8"
                                Background="#FFE67E22" Foreground="White" FontWeight="Bold"/>
                    </Grid>

                    <!-- 通信数据 -->
                    <TextBlock Grid.Row="1" Text="通信数据:" FontWeight="Bold" Margin="5,15,5,5"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="发送数据:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SentData}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5" FontFamily="Consolas"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="接收数据:" VerticalAlignment="Center" Margin="5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ReceivedData}" IsReadOnly="True" 
                                 Margin="5" Background="#FFF5F5F5" FontFamily="Consolas"/>

                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="清空结果" 
                                Command="{Binding ClearResultsCommand}" Margin="5" Padding="10,5"/>
                    </Grid>

                    <!-- 说明 -->
                    <Border Grid.Row="3" Background="#FFECF0F1" CornerRadius="5" Margin="5,20,5,5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="使用说明:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="1. 选择串口号（默认COM2）并点击连接" TextWrapping="Wrap"/>
                            <TextBlock Text="2. 设置从站地址（默认2）" TextWrapping="Wrap"/>
                            <TextBlock Text="3. 读取：设置起始地址和数量，点击读取" TextWrapping="Wrap"/>
                            <TextBlock Text="4. 写入：设置寄存器地址和值，点击写入" TextWrapping="Wrap"/>
                            <TextBlock Text="5. 支持16进制、UInt16、Float格式显示" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Background="#FF34495E">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="物联网控制技术实验" Foreground="#FFBDC3C7"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
