<Window x:Class="UJS_ModbusMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UJS_ModbusMaster.Helpers"
        mc:Ignorable="d"
        Title="Modbus RTU Master - 物联网控制技术实验" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5">

    <Window.Resources>
        <helpers:BooleanToConnectTextConverter x:Key="BooleanToConnectTextConverter"/>
        <helpers:ConnectionStatusConverter x:Key="ConnectionStatusConverter"/>

        <!-- Material Design Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF1976D2"/>
        <SolidColorBrush x:Key="PrimaryDarkColor" Color="#FF1565C0"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF2196F3"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFFF9800"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#FFF44336"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#FF212121"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#FF757575"/>
        <SolidColorBrush x:Key="DividerColor" Color="#FFBDBDBD"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>

        <!-- Material Card Style -->
        <Style x:Key="MaterialCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1" Color="#FF000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material Button Style -->
        <Style x:Key="MaterialButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Material TextBox Style -->
        <Style x:Key="MaterialTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
        </Style>

        <!-- Material ComboBox Style -->
        <Style x:Key="MaterialComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="MaterialLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="20,25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="White" CornerRadius="4" Padding="8" Margin="0,0,15,0">
                        <TextBlock Text="M" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Modbus RTU Master" Foreground="White" FontSize="22" FontWeight="Medium"/>
                        <TextBlock Text="物联网控制技术实验" Foreground="#90CAF9" FontSize="13" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#1AFFFFFF" CornerRadius="20" Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Serial Port Settings Card -->
        <Border Grid.Row="1" Style="{StaticResource MaterialCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="串口设置" Style="{StaticResource SectionTitle}"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Port -->
                    <StackPanel Grid.Column="0" Margin="10,0">
                        <TextBlock Text="串口号" Style="{StaticResource MaterialLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}"
                                  Style="{StaticResource MaterialComboBox}"/>
                    </StackPanel>

                    <!-- Baud Rate -->
                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock Text="波特率" Style="{StaticResource MaterialLabel}"/>
                        <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding BaudRate}"
                                  Style="{StaticResource MaterialComboBox}"/>
                    </StackPanel>

                    <!-- Parity -->
                    <StackPanel Grid.Column="2" Margin="10,0">
                        <TextBlock Text="校验位" Style="{StaticResource MaterialLabel}"/>
                        <ComboBox ItemsSource="{Binding Parities}" SelectedItem="{Binding Parity}"
                                  Style="{StaticResource MaterialComboBox}"/>
                    </StackPanel>

                    <!-- Data Bits -->
                    <StackPanel Grid.Column="3" Margin="10,0">
                        <TextBlock Text="数据位" Style="{StaticResource MaterialLabel}"/>
                        <ComboBox ItemsSource="{Binding DataBitsList}" SelectedItem="{Binding DataBits}"
                                  Style="{StaticResource MaterialComboBox}"/>
                    </StackPanel>

                    <!-- Stop Bits -->
                    <StackPanel Grid.Column="4" Margin="10,0">
                        <TextBlock Text="停止位" Style="{StaticResource MaterialLabel}"/>
                        <ComboBox ItemsSource="{Binding StopBitsList}" SelectedItem="{Binding StopBits}"
                                  Style="{StaticResource MaterialComboBox}"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Bottom">
                        <Button Content="刷新" Command="{Binding RefreshPortsCommand}" 
                                Margin="0,0,10,0" Padding="15,8"/>
                        <Button Content="{Binding IsConnected, Converter={StaticResource BooleanToConnectTextConverter}}" 
                                Command="{Binding ConnectCommand}" Width="100">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ErrorColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Read Section -->
            <Border Grid.Column="0" Style="{StaticResource MaterialCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Icon -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="读取保持寄存器" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="功能码 03" Foreground="{StaticResource TextSecondaryColor}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Settings -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="从站地址" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding SlaveId}" Style="{StaticResource MaterialTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="起始地址" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding ReadStartAddress}" Style="{StaticResource MaterialTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="寄存器数量" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding ReadQuantity}" Style="{StaticResource MaterialTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Read Button -->
                    <Button Grid.Row="2" Content="读取寄存器" Command="{Binding ReadRegistersCommand}" 
                            Style="{StaticResource MaterialButton}" HorizontalAlignment="Stretch" Margin="0,0,0,20"/>

                    <!-- Results -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="读取结果" FontSize="14" FontWeight="Medium" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryColor}"/>

                            <!-- Hex Result -->
                            <Border Background="#FFF5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="16进制" Style="{StaticResource MaterialLabel}" Margin="0"/>
                                    <TextBox Text="{Binding HexResult}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- UInt16 Result -->
                            <Border Background="#FFF5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="UInt16" Style="{StaticResource MaterialLabel}" Margin="0"/>
                                    <TextBox Text="{Binding Uint16Result}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Float Result -->
                            <Border Background="#FFF5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Float" Style="{StaticResource MaterialLabel}" Margin="0"/>
                                    <TextBox Text="{Binding FloatResult}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Raw Bytes -->
                            <Border Background="#FFF5F5F5" CornerRadius="4" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="原始字节" Style="{StaticResource MaterialLabel}" Margin="0"/>
                                    <TextBox Text="{Binding RawBytesResult}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Write Section -->
            <Border Grid.Column="1" Style="{StaticResource MaterialCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Icon -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="写入单个寄存器" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="功能码 06" Foreground="{StaticResource TextSecondaryColor}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Settings -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="从站地址" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding SlaveId}" Style="{StaticResource MaterialTextBox}" IsReadOnly="True"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="寄存器地址" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding WriteAddress}" Style="{StaticResource MaterialTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="写入值" Style="{StaticResource MaterialLabel}"/>
                            <TextBox Text="{Binding WriteValue}" Style="{StaticResource MaterialTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Write Button -->
                    <Button Grid.Row="2" Content="写入寄存器" Command="{Binding WriteRegisterCommand}" 
                            Background="{StaticResource WarningColor}" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialButton}">
                                <Setter Property="Background" Value="{StaticResource WarningColor}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF57C00"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Communication Data -->
                    <TextBlock Grid.Row="3" Text="通信数据" FontSize="14" FontWeight="Medium" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryColor}"/>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Sent Data -->
                            <Border Background="#FFE8F5E9" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="发送数据" Style="{StaticResource MaterialLabel}" Margin="0" Foreground="{StaticResource SuccessColor}"/>
                                    <TextBox Text="{Binding SentData}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Received Data -->
                            <Border Background="#FFE3F2FD" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="接收数据" Style="{StaticResource MaterialLabel}" Margin="0" Foreground="{StaticResource PrimaryColor}"/>
                                    <TextBox Text="{Binding ReceivedData}" IsReadOnly="True" 
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Clear Button -->
                            <Button Content="清空结果" Command="{Binding ClearResultsCommand}" 
                                    HorizontalAlignment="Left" Padding="20,8"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{StaticResource PrimaryColor}" Padding="20,15">
            <Grid>
                <TextBlock Text="物联网控制技术实验" Foreground="#90CAF9" FontSize="13" HorizontalAlignment="Left"/>
                <TextBlock Text="Modbus RTU Master v1.0" Foreground="#90CAF9" FontSize="13" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
